{
  "name": "office365",
  "version": "0.1.0",
  "description": "Microsoft 365 \u2014 Mail, Calendar, Teams, Files via MS Graph",
  "provider": "core",
  "capabilities": [
    "mcp"
  ],
  "entry_point": "provider:Office365Plugin",
  "icon": "ph ph-microsoft-outlook-logo",
  "author": "openhort",
  "llming_type": "connector",
  "credentials": [
    {
      "id": "ms_oauth",
      "type": "oauth2",
      "label": "Microsoft Account",
      "provider": "microsoft",
      "scopes": [
        "User.Read",
        "Mail.Read",
        "Mail.Send",
        "Calendar.ReadWrite",
        "Files.Read"
      ],
      "expires": true,
      "refresh_supported": true,
      "remote_update": false,
      "help_url": "https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps",
      "help_text": "Register an app in Azure AD to get a client ID"
    }
  ],
  "mcp": true
}