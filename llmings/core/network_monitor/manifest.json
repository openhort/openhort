{
  "name": "network-monitor",
  "version": "0.1.0",
  "description": "Monitors network interfaces, bandwidth usage, and connection status",
  "provider": "core",
  "capabilities": [
    "monitor",
    "mcp"
  ],
  "entry_point": "provider:NetworkMonitor",
  "icon": "ph ph-wifi-high",
  "author": "openhort",
  "llming_type": "monitor",
  "features": {
    "interfaces": {
      "description": "Monitor network interfaces and IP addresses",
      "default": true
    },
    "bandwidth": {
      "description": "Monitor bandwidth usage per interface",
      "default": true
    }
  },
  "jobs": [
    {
      "id": "poll-network",
      "method": "poll_network",
      "interval_seconds": 5,
      "run_on_activate": true
    }
  ],
  "mcp": true,
  "ui_widgets": [
    "network-monitor-panel"
  ],
  "ui_script": "static/cards.js"
}