+    # ===== Auto-login: single URL that sets proxy + hosted app cookies =====
+
+    @app.get("/_auto")
+    async def auto_login(request: Request) -> Response:
+        """One-click login: sets proxy session + hosted app auth, then redirects.
+
+        Usage: /_auto?user=admin&pass=OpenHort2026!&host=<id>&app_email=admin@openhort.local&app_pass=OpenHort2026!&redirect=/app/workflows/ui/
+        All params are in the URL — bookmarkable for dev/testing.
+        """
+        params = request.query_params
+        username = params.get("user", "")
+        password = params.get("pass", "")
+        host_id = params.get("host", "")
+        app_email = params.get("app_email", "")
+        app_pass = params.get("app_pass", "")
+        redirect_to = params.get("redirect", "/viewer")
+
+        # 1. Proxy login
+        if username and password:
+            user = store.get_user(username)
+            if user and verify_password(password, user.password_hash):
+                request.session["username"] = username
+
+        # 2. Select host (or auto-select first online)
+        logged_in_user = request.session.get("username", "")
+        if host_id:
+            request.session["host_id"] = host_id
+        elif logged_in_user:
+            for h in store.get_hosts_for_user(logged_in_user):
+                if h.host_id in _tunnels:
+                    request.session["host_id"] = h.host_id
+                    host_id = h.host_id
+                    break
+
+        # 3. Login to hosted app (if credentials provided and tunnel available)
+        tunnel = _tunnels.get(request.session.get("host_id", ""))
+        app_cookie = ""
+        if tunnel and app_email and app_pass:
+            try:
+                resp = await tunnel.proxy_request(
+                    "POST", redirect_to.rstrip("/") + "/rest/login",
+                    {"content-type": "application/json"},
+                    json.dumps({"emailOrLdapLoginId": app_email, "password": app_pass}).encode(),
+                )
+                # Extract Set-Cookie from hosted app response
+                raw_headers = resp.get("headers", {})
+                for k, v in raw_headers.items():
+                    if k.lower() == "set-cookie" and "n8n-auth" in v.lower():
+                        app_cookie = v
+            except Exception:
+                pass
+
+        response = Response(status_code=302, headers={"Location": redirect_to})
+        if app_cookie:
+            response.headers.append("Set-Cookie", app_cookie)
+        return response
+
