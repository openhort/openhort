{
  "name": "process-manager",
  "version": "0.1.0",
  "description": "View running processes, sort by CPU/memory, kill processes",
  "provider": "core",
  "platforms": ["darwin", "linux", "win32"],
  "capabilities": ["tool", "mcp"],
  "entry_point": "provider:ProcessManager",
  "icon": "ph ph-list-checks",
  "author": "openhort",
  "plugin_type": "tool",
  "features": {
    "kill": { "description": "Allow killing processes", "default": false }
  },
  "jobs": [
    {
      "id": "poll-processes",
      "method": "poll_processes",
      "interval_seconds": 10,
      "run_on_activate": true
    }
  ],
  "mcp": true,
  "ui_widgets": ["process-manager-panel"],
  "ui_script": "static/panel.js"
}
