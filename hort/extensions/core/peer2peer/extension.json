{
  "name": "peer2peer",
  "version": "0.1.0",
  "description": "P2P hole punching for direct connections — bypasses relay servers",
  "provider": "core",
  "platforms": ["darwin", "linux", "win32"],
  "capabilities": ["connector", "mcp"],
  "entry_point": "provider:HolepunchPlugin",
  "icon": "ph ph-plugs-connected",
  "author": "openhort",
  "plugin_type": "connector",
  "features": {
    "azure_vm": { "description": "Azure VM provisioning for testing", "default": true }
  },
  "jobs": [
    {
      "id": "check-vm-status",
      "method": "check_vm_status",
      "interval_seconds": 60,
      "enabled_feature": "azure_vm"
    }
  ],
  "mcp": true,
  "ui_widgets": ["peer2peer-panel"],
  "ui_script": "static/panel.js",
  "config_schema": {
    "type": "object",
    "properties": {
      "stun_servers": {
        "type": "array",
        "items": {"type": "string"},
        "default": ["stun.l.google.com:19302"]
      },
      "azure_resource_group": {
        "type": "string",
        "default": "openhort-peer2peer-rg"
      },
      "azure_region": {
        "type": "string",
        "default": "westeurope"
      },
      "azure_vm_size": {
        "type": "string",
        "default": "Standard_B1ls"
      },
      "azure_vm_name": {
        "type": "string",
        "default": "openhort-punch-test"
      }
    }
  }
}
