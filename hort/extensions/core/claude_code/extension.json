{
  "name": "claude-code",
  "version": "0.1.0",
  "description": "Claude Code — AI coding assistant with sandboxed container execution",
  "provider": "core",
  "platforms": ["darwin", "linux", "win32"],
  "capabilities": ["mcp", "ui"],
  "entry_point": "provider:ClaudeCodePlugin",
  "icon": "ph ph-robot",
  "author": "openhort",
  "plugin_type": "llm",
  "features": {
    "chat": { "description": "Chat with Claude via connectors", "default": true },
    "container": { "description": "Run Claude in sandboxed Docker container", "default": true }
  },
  "mcp": true,
  "ui_script": "static/panel.js"
}
